# ── Gemini Live ──────────────────────────────────────────────
GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.5-flash-native-audio-preview-12-2025

# ── Telcoflow (sandbox) ─────────────────────────────────────
WSS_API_KEY=
WSS_CONNECTOR_UUID=

# ── AWS / Amazon Nova 2 Sonic (optional — skips transcription if not set)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_DEFAULT_REGION=us-east-1
# NOVA_SONIC_MODEL_ID=amazon.nova-2-sonic-v1:0

# ── Slack (optional — logs notifications if not set) ─────────
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/T.../B.../...
# SLACK_CHANNEL=#incoming-calls

# ── Business hours ───────────────────────────────────────────
# BUSINESS_NAME=YOUR_COMPANY_NAME
# BUSINESS_TIMEZONE=Asia/Singapore
# BUSINESS_OPEN_HOUR=9
# BUSINESS_CLOSE_HOUR=17

# ── Storage ──────────────────────────────────────────────────
# DB_PATH=voicemail.db
# RECORDINGS_DIR=recordings
