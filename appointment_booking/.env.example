# ── Gemini Live ──────────────────────────────────────────────
GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.5-flash-native-audio-preview-12-2025
# GEMINI_SAMPLE_RATE=24000

# ── Telcoflow ───────────────────────────────────────────────
# Sandbox mode (default)
WSS_API_KEY=
WSS_CONNECTOR_UUID=

# Production mode (uncomment and fill for mTLS)
# TELCOFLOW_MODE=production
# TELCOFLOW_CERT_PATH=/etc/certs/client.pem
# TELCOFLOW_KEY_PATH=/etc/certs/client.key

# ── Twilio SMS (optional — logs SMS if not configured) ──────
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_FROM_NUMBER=+1234567890

# ── Business settings ───────────────────────────────────────
# BUSINESS_NAME=YOUR_COMPANY_NAME Clinic
# BUSINESS_OPEN_HOUR=9
# BUSINESS_CLOSE_HOUR=17
# BUSINESS_SLOT_MINUTES=30
# BUSINESS_SERVICES=General Checkup,Dental Cleaning,Eye Exam,Physiotherapy,Consultation

# ── Database ────────────────────────────────────────────────
# DB_PATH=appointments.db
